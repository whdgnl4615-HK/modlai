# ─────────────────────────────────────────────
# AI Model API Keys
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...           # https://console.anthropic.com/settings/keys
GOOGLE_API_KEY=AIza...                 # https://aistudio.google.com/apikey
OPENAI_API_KEY=sk-proj-...             # https://platform.openai.com/api-keys
STABILITY_API_KEY=sk-...               # https://platform.stability.ai/account/keys

# ─────────────────────────────────────────────
# Supabase (Auth + DB + Storage)
# ─────────────────────────────────────────────
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...          # safe to expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...  # NEVER expose — server only

# ─────────────────────────────────────────────
# Stripe (default PG)
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────────
# Balance (optional alternative PG)
# ─────────────────────────────────────────────
BALANCE_API_KEY=
BALANCE_API_BASE=https://api.getbalance.com/v2
BALANCE_WEBHOOK_SECRET=
BALANCE_TERMS_DAYS=30

# ─────────────────────────────────────────────
# Publishing Channels
# Channel credentials are stored PER-USER in channel_connections table,
# not here — users connect their own Shopify/Faire stores.
# Only override these if you need custom API endpoints:
# ─────────────────────────────────────────────
# FAIRE_API_BASE=https://www.faire.com/external-api/v2

# ─────────────────────────────────────────────
# Cron (scheduled data sync every 6h)
# Optional — Vercel cron header is sufficient. Set for extra safety.
# ─────────────────────────────────────────────
# CRON_SECRET=your-random-secret-here

# ─────────────────────────────────────────────
# Email (Resend — invitations & welcome messages)
# https://resend.com → Free 3000/month
# ─────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM=MODLai <noreply@yourdomain.com>  # Must use a domain verified in Resend

# ─────────────────────────────────────────────
# Frontend URL (used for CORS + invite link base)
# Example: https://app.modlai.com (no trailing slash)
# ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
